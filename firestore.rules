rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Memories — personal AI memory bank
      match /memories/{memId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Library — saved answers, artifacts, notes, research
      match /library/{libId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Conversations
    match /conversations/{convId} {
      allow read, write: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;

      // Prevent userId reassignment (privilege escalation guard)
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;

      // Messages subcollection — verified through parent ownership
      match /messages/{msgId} {
        allow read, write: if request.auth != null &&
          get(/databases/$(database)/documents/conversations/$(convId)).data.userId == request.auth.uid;
      }
    }
  }
}
